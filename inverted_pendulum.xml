<mujoco model="inverted_pendulum">

    <compiler angle="radian" coordinate="local"/>
    <option timestep="0.002" gravity="0 0 -9.81" integrator="Euler"/>
    <default>
        <joint damping="0.0" armature="0.0"/>
        <geom friction="0.0 0.0 0.0" rgba="0.7 0.7 0.7 1"/>
        <motor ctrllimited="true" ctrlrange="-100 100"/>
    </default>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1"/>

        <!-- ground -->
        <geom name="ground" type="plane" pos="0 0 0" size="5 5 0.1" rgba="0.9 0.9 0.9 1"/>

        <!-- rail -->
        <geom name="rail" type="capsule"
              fromto="-2 0 0.1  2 0 0.1"
              size="0.015"
              rgba="0.2 0.2 0.2 1"/>

        <!-- cart -->
        <body name="cart" pos="0 0 0.1">
            <inertial pos="0 0 0" mass="0.5" diaginertia="0.002 0.002 0.002"/>

            <joint name="slider"
                   type="slide"
                   axis="1 0 0"
                   limited="true"
                   range="-1.5 1.5"
                   damping="0.05"/>

            <geom name="cart_geom"
                  type="box"
                  size="0.10 0.06 0.05"
                  rgba="0.1 0.5 0.8 1"/>

            <!-- pole -->
            <body name="pole" pos="0 0 0">
                <!-- COM ở giữa thanh: z = 0.3 -->
                <inertial pos="0 0 0.3" mass="0.2" diaginertia="0.006 0.006 0.0001"/>

                <!-- quay quanh trục y, theta=0 là thanh hướng lên +z -->
                <joint name="hinge"
                       type="hinge"
                       axis="0 1 0"
                       damping="0.001"/>

                <geom name="pole_geom"
                      type="capsule"
                      fromto="0 0 0   0 0 0.6"
                      size="0.015"
                      rgba="0.85 0.2 0.2 1"/>

                <site name="tip" pos="0 0 0.6" size="0.02" rgba="0 0 0 1"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="cart_force" joint="slider" gear="50"/>
    </actuator>

</mujoco>