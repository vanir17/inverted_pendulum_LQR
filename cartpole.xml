<mujoco model="cartpole">
    
    <default>
        <joint damping="0.05" armature="0.01"/>
        <geom contype="1" conaffinity="1" friction="1 0.1 0.1" rgba="0.7 0.7 0.7 1"/>
    </default>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 5" dir="0 0 -1"/>
        <geom type="plane" pos="0 0 0" size="10 10 .05" rgba="0.8 0.9 0.8 1"/>
        <geom type="capsule" pos="0 0 0.2" quat="0.707 0 0.707 0" size="0.02 2" rgba="0.3 0.3 0.3 1"/>

        <body name="cart" pos="0 0 0.2">
     <      inertial pos="0 0 0" mass="0.5" diaginertia="0.01 0.01 0.01"/>
            <joint name="slider" type="slide" pos="0 0 0" axis="1 0 0" 
            limited="true" range="-1.0 1.0" damping="0.1" frictionloss="0.01"/>
            <geom type="box" size="0.1 0.05 0.05" rgba="0 0.5 0.8 1"/>

            <body name="pole" pos="0 0 0">
                <inertial pos="0 0 0.3" mass="0.2" diaginertia="0.006 0.006 0.0001"/>
                <joint name="hinge" type="hinge" pos="0 0 0" axis="0 1 0" damping="0.001"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.6" size="0.015" rgba="0.8 0.2 0.2 1"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="force_actuator" joint="slider" gear="1" ctrllimited="true" ctrlrange="-100 100"/>
    </actuator>
</mujoco>